Detection
events:
  - NEW_PROCESS
  - EXISTING_PROCESS
op: and
rules:
  - op: is windows
  - op: or
    rules:
      - case sensitive: false
        op: contains
        path: event/FILE_PATH
        value: lazagne.exe
      - case sensitive: false
        op: contains
        path: event/COMMAND_LINE
        value: LaZagne
      - case sensitive: false
        op: ends with
        path: event/FILE_PATH
        value: lazagne
      - case sensitive: false
        op: contains
        path: event/FILE_PATH
        value: all
      - case sensitive: false
        op: contains
        path: event/FILE_PATH
        value: USER_NAME
Response
- action: report
  metadata:
    author: isaac kiua
    description: TEST - Detects Lazagne Usage
    falsepositives:
      - ToTheMoon
    level: high
    tags:
      - attack.credential_access
  name: lazagne hacktool
